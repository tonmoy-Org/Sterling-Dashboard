        "action": "js_code_run",
        "js_code": "(async () => { const sleep = (ms) => new Promise(r => setTimeout(r, ms)); let boxes = []; for (let i = 0; i < 50; i++) { boxes = document.querySelectorAll(\".filter-multiselect .checkbox\"); if (boxes.length > 0) break; await sleep(100); } if (boxes.length === 0) return; for (const item of boxes) { const cb = item.querySelector(\"input\"); if (!cb || cb.checked) continue; item.scrollIntoView({ block: \"center\" }); await sleep(50); const trigger = (el) => { [\"mousedown\", \"mouseup\", \"click\"].forEach(n => el.dispatchEvent(new MouseEvent(n, { bubbles: true, cancelable: true, view: window }))); }; trigger(item); if (cb && !cb.checked) trigger(cb); if (cb && !cb.checked) { cb.checked = true; cb.dispatchEvent(new Event('input', { bubbles: true })); cb.dispatchEvent(new Event('change', { bubbles: true })); } await sleep(100); } })();"
